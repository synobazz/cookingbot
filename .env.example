# App
APP_BASE_URL=http://localhost:3000
APP_SESSION_SECRET=change-me-to-a-long-random-string
APP_ADMIN_PASSWORD=change-me

# Local development: file:./dev.db
# Docker/Portainer: file:/data/cookingbot.db
DATABASE_URL=file:/data/cookingbot.db

# OpenAI-compatible LLM
OPENAI_API_KEY=
# Optional fallback model if Planner/Remix model are not set
OPENAI_MODEL=
# Recommended split: cheaper/faster planner, stronger creative remix
OPENAI_PLANNER_MODEL=gpt-5.4-mini
OPENAI_REMIX_MODEL=gpt-5.5
OPENAI_BASE_URL=

# Paprika Cloud Sync (server-side only)
PAPRIKA_EMAIL=
PAPRIKA_PASSWORD=
PAPRIKA_API_BASE=https://www.paprikaapp.com/api

# Microsoft To Do export (Microsoft Entra app registration)
# Redirect URI: ${APP_BASE_URL}/api/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=consumers

# Set to "true" only when running behind a trusted reverse proxy that
# sets X-Forwarded-For correctly. Otherwise leave unset to avoid
# IP-spoofing the login rate limiter.
TRUST_PROXY=

# Docker convenience: keep true for NAS/Portainer auto schema sync.
# Set to false if you switch to manual Prisma migrations later.
PRISMA_DB_PUSH_ON_START=true

# Bearer-Token, das der MCP-Server (für Claude/ChatGPT-Integration) verlangt.
# Wenn leer, ist der /mcp-Endpoint deaktiviert. Erzeuge einen Wert mit
#   openssl rand -base64 48
# und trage ihn unten ein. Mindestlänge 32 Zeichen, in Produktion erzwungen.
MCP_BEARER_TOKEN=
