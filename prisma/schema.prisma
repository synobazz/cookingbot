generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Recipe {
  id             String    @id @default(cuid())
  paprikaUid     String?   @unique
  hash           String?
  name           String
  description    String?   @default("")
  ingredients    String    @default("")
  directions     String    @default("")
  notes          String?   @default("")
  servings       String?   @default("")
  prepTime       String?   @default("")
  cookTime       String?   @default("")
  totalTime      String?   @default("")
  difficulty     String?   @default("")
  rating         Int       @default(0)
  categoriesJson String    @default("[]")
  source         String?   @default("")
  sourceUrl      String?   @default("")
  imageUrl       String?   @default("")
  photo          String?   @default("")
  photoLarge     String?   @default("")
  photoHash      String?   @default("")
  photoUrl       String?   @default("")
  excludeFromPlanning Boolean @default(false)
  inTrash        Boolean   @default(false)
  onFavorites    Boolean   @default(false)
  /// Herkunft des Rezepts: "paprika" (von Paprika gesynct), "local-llm" (vom Assistenten erstellt) oder "manual" (per Hand angelegt). Bestimmt ob ein Re-Sync den Datensatz \u00fcberschreibt.
  origin         String    @default("paprika")
  lastSyncedAt   DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  mealItems      MealItem[]
  history        MealHistory[]

  @@index([inTrash, excludeFromPlanning])
  @@index([onFavorites, rating])
  @@index([updatedAt])
  @@index([origin])
}

model MealPlan {
  id           String        @id @default(cuid())
  title        String
  startsOn     DateTime
  daysJson     String        @default("[]")
  people       Float         @default(2.5)
  status       String        @default("draft")
  llmNotes     String?       @default("")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  items        MealItem[]
  shoppingList ShoppingList?
}

model MealItem {
  id           String   @id @default(cuid())
  mealPlanId   String
  mealPlan     MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  date         DateTime
  dayName      String
  title        String
  type         String   @default("dinner")
  recipeId     String?
  recipe       Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  isRemix      Boolean  @default(false)
  remixSource  String?  @default("")
  reasoning    String?  @default("")
  ingredients  String   @default("")
  instructions String   @default("")
  createdAt    DateTime @default(now())

  @@index([mealPlanId])
  @@index([recipeId])
}

model ShoppingList {
  id                 String             @id @default(cuid())
  mealPlanId         String             @unique
  mealPlan           MealPlan           @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  title              String
  microsoftListId    String?            @default("")
  microsoftListName  String?            @default("")
  lastMicrosoftSyncAt DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  items              ShoppingListItem[]
}

model ShoppingListItem {
  id                String       @id @default(cuid())
  shoppingListId    String
  shoppingList      ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  name              String
  quantity          String?      @default("")
  category          String?      @default("")
  checked           Boolean      @default(false)
  source            String?      @default("")
  order             Int          @default(0)
  microsoftTaskId   String?      @default("")
  microsoftTaskUrl  String?      @default("")
  microsoftSyncedAt DateTime?

  @@index([shoppingListId, order])
}

model MicrosoftConnection {
  id                    String   @id @default("default")
  accountName           String?  @default("")
  accountEmail          String?  @default("")
  encryptedAccessToken  String
  encryptedRefreshToken String
  expiresAt             DateTime
  scopes                String   @default("")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Eintrag in der virtuellen Vorratskammer.
/// Wenn eine Zutat hier liegt, taucht sie nicht in der generierten
/// Einkaufsliste auf (oder wird in den "Hast du noch?"-Block verschoben).
/// `expiresOn` ist optional und kann später für Ablauf-Erinnerungen genutzt werden.
model PantryItem {
  id        String    @id @default(cuid())
  /// Normalisierter Schlüssel (lowercase, Singular) – wird beim Vergleich genutzt.
  key       String    @unique
  /// Anzeigename, z. B. "Olivenöl"
  name      String
  /// Optionale Mengenangabe als Freitext, z. B. "1 Flasche", "500 g". Nicht maschinell ausgewertet.
  quantity  String?   @default("")
  /// Optionales Verfallsdatum für künftige Reminder.
  expiresOn DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

/// Wann ein Rezept tatsächlich gekocht wurde (vom Plan getriggert oder
/// manuell als "gemacht" markiert). Wird vom Planner als Recency-Filter
/// gegen Wiederholungen in den letzten N Tagen genutzt.
model MealHistory {
  id        String   @id @default(cuid())
  recipeId  String?
  recipe    Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  /// Falls Remix oder freier Eintrag ohne Recipe-Link.
  title     String
  cookedOn  DateTime
  source    String   @default("manual")
  createdAt DateTime @default(now())

  @@index([cookedOn])
  @@index([recipeId, cookedOn])
}
